---
import { getCollection } from "astro:content";

const all = await getCollection("blog", ({ data }) => !data.draft);
const posts = all
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<ul class="writing-list" role="list">
  {posts.length === 0 && (
    <li class="writing-item">
      <span class="writing-date">soon</span>
      <div>
        <p class="writing-title">First post coming shortly</p>
        <p class="writing-dek">A note on what I'm building, why, and what I'm trying to learn from it.</p>
      </div>
    </li>
  )}
  {posts.map((p) => (
    <li class="writing-item">
      <span class="writing-date">{fmtDate(p.data.date)}</span>
      <a href={`/blog/${p.id}/`} style="display:block">
        <p class="writing-title">{p.data.title}</p>
        <p class="writing-dek">{p.data.dek}</p>
      </a>
    </li>
  ))}
</ul>

<a class="writing-more" href="/blog/">All writing <span class="arrow">→</span></a>
