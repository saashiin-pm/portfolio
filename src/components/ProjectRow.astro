---
interface Props {
  index: string;
  title: string;
  dek: string;
  href: string;
  year?: string;
  tag?: string;
  image?: string;
  imageAlt?: string;
  flipped?: boolean;
  external?: boolean;
  caseStudyHref?: string;
  liveLabel?: string;
}

const {
  index,
  title,
  dek,
  href,
  year = "",
  tag = "",
  image,
  imageAlt,
  flipped = false,
  external = false,
  caseStudyHref,
  liveLabel = "Visit live",
} = Astro.props;
---

<article class:list={["project", { "is-flipped": flipped }]}>
  <a
    class="project-media"
    href={caseStudyHref ?? href}
    target={!caseStudyHref && external ? "_blank" : undefined}
    rel={!caseStudyHref && external ? "noopener noreferrer" : undefined}
    aria-label={title}
  >
    {image ? (
      <img
        src={image}
        alt={imageAlt ?? `Preview of ${title}`}
        width="1200"
        height="900"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <span class="placeholder">[ project preview ]</span>
    )}
  </a>
  <div class="project-body">
    <p class="project-meta">
      <span class="num">{index}</span>
      {year && <span>{year}</span>}
      {tag && <span>{tag}</span>}
    </p>
    <h3 class="project-title">{title}</h3>
    <p class="project-dek">{dek}</p>

    <div class="project-ctas">
      {caseStudyHref && (
        <a class="btn" href={caseStudyHref}>
          Read case study <span class="arrow">→</span>
        </a>
      )}
      <a
        class:list={["btn", caseStudyHref ? "btn-ghost" : ""]}
        href={href}
        target={external ? "_blank" : undefined}
        rel={external ? "noopener noreferrer" : undefined}
      >
        {liveLabel} <span class="arrow">{external ? "↗" : "→"}</span>
      </a>
    </div>
  </div>
</article>
