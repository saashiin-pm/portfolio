---
interface Props {
  index: string;
  title: string;
  dek: string;
  href: string;
  year?: string;
  tag?: string;
  image?: string;
  imageAlt?: string;
  flipped?: boolean;
  external?: boolean;
}

const {
  index,
  title,
  dek,
  href,
  year = "",
  tag = "",
  image,
  imageAlt,
  flipped = false,
  external = false,
} = Astro.props;
---

<article class:list={["project", { "is-flipped": flipped }]}>
  <a class="project-media" href={href} target={external ? "_blank" : undefined} rel={external ? "noopener noreferrer" : undefined} aria-label={title}>
    {image ? (
      <img
        src={image}
        alt={imageAlt ?? `Preview of ${title}`}
        width="1200"
        height="900"
        loading="lazy"
        decoding="async"
      />
    ) : (
      <span class="placeholder">[ project preview ]</span>
    )}
  </a>
  <div class="project-body">
    <p class="project-meta">
      <span class="num">{index}</span>
      {year && <span>{year}</span>}
      {tag && <span>{tag}</span>}
    </p>
    <h3 class="project-title">{title}</h3>
    <p class="project-dek">{dek}</p>
    <a
      class="project-link"
      href={href}
      target={external ? "_blank" : undefined}
      rel={external ? "noopener noreferrer" : undefined}
    >
      View project <span class="arrow">→</span>
    </a>
  </div>
</article>
